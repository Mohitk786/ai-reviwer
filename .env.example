# =============================================================================
# RAG — Environment template
# Copy to .env.local for local dev. NEVER commit .env / .env.local.
# Loader & validator: packages/shared/src/env.ts (Zod schema; fails fast on missing/invalid).
# =============================================================================

# ---- Core ----
# Where the web app runs (used in OAuth callbacks and absolute URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# 'development' | 'test' | 'production'.
NODE_ENV=development

# ---- Database ----
# Single DATABASE_URL is shared by Prisma, pg-boss, and the app. One connection origin.
# Local Docker default below; production should be a managed Postgres with pgvector enabled.
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag?schema=public

# ---- Crypto ----
# Master key for ProviderCredential encryption (AES-256-GCM).
# Must be 32 bytes hex-encoded (64 hex chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_me_with_64_hex_chars

# Session signing key (JWT HMAC). Same generator as above is fine.
SESSION_SECRET=replace_me_with_64_hex_chars

# ---- GitHub App ----
# Created at https://github.com/settings/apps/new
# Slug is the URL portion: github.com/apps/<slug>. Used to build install URL.
GITHUB_APP_SLUG=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM private key. Multi-line value: keep newlines as \n in env, OR use a separate file path.
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----

-----END RSA PRIVATE KEY-----
"
# Webhook HMAC secret. Used to verify inbound webhook signatures.
GITHUB_WEBHOOK_SECRET="webhook-secret"

# ---- Default LLM provider (app-owned, used when an installation has no BYO credential) ----
# Currently OpenAI. To change defaults later, swap these and the resolver default config.
OPENAI_API_KEY=""
OPENAI_DEFAULT_CHAT_MODEL=gpt-4.1-mini
OPENAI_DEFAULT_EMBEDDING_MODEL=text-embedding-3-large
# Embedding dimensions — fixed at table-creation time. Changing this requires a re-index.
OPENAI_EMBEDDING_DIMENSIONS=1536

# ---- Stripe (optional in MVP — leave blank until billing is enforced) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- Observability ----
LOG_LEVEL=info
