{
  "name": "rag",
  "private": true,
  "description": "Engineering operational memory — RAG over GitHub PRs/issues/commits, providing teams with a queryable history of debugging knowledge.",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "npm --workspace @repo/db run migrate:dev",
    "db:generate": "npm --workspace @repo/db run generate",
    "db:seed": "npm --workspace @repo/db run seed",
    "db:studio": "npm --workspace @repo/db run studio",
    "docker:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker compose -f docker-compose.dev.yml down",
    "docker:build": "docker build -t rag-app:local .",
    "docker:run": "docker compose up --build"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prettier": "^3.7.4",
    "turbo": "^2.9.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
