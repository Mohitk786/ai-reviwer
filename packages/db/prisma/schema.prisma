// =============================================================================
// RAG → AI Code Reviewer — Prisma schema
//
// Models the GitHub object graph faithfully (PR / Issue / Comment / Commit / Reference)
// alongside identity, subscription, feature flag, provider credential, and
// AI review tables.
//
// Design principles:
//   1. Faithful to GitHub's object graph — do NOT pre-collapse into a generic
//      `documents` table. Review context queries need the structure.
//   2. AiReview is pinned to a `commitSha` — one review per commit, immutable
//      after posting. Re-review on push = new AiReview row.
//   3. AiReviewComment stores actual file line numbers (not GitHub diff positions);
//      conversion to GitHub API `position`/`line` happens at post time.
//   4. ReviewConfiguration supports per-installation defaults (repositoryId = NULL)
//      and per-repository overrides. Uniqueness of the NULL case is enforced at the
//      service layer (Postgres UNIQUE allows multiple NULLs; partial index not
//      required for MVP scale).
//   5. Chunk/ChunkEmbedding/Query tables retained in schema for backward-compatible
//      migration; will be dropped in a separate destructive migration after code is
//      fully removed.
//
// References: see ./README.md for design rationale.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../src/generated/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector enables the `vector` column type used by ChunkEmbedding.
  extensions = [pgvector(map: "vector")]
}

// -----------------------------------------------------------------------------
// Identity & access
// -----------------------------------------------------------------------------

/// A GitHub user who has logged into our app.
model User {
  id            String   @id @default(cuid())
  githubId      Int      @unique
  githubLogin   String
  email         String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  installations InstallationUser[]

  @@index([githubLogin])
}

/// A GitHub App installation — represents an org or user that has authorized our app.
/// Per-installation rate limits and webhooks are scoped here.
model Installation {
  id            String           @id @default(cuid())
  githubId      Int              @unique
  accountLogin  String
  accountType   AccountType
  // True when org admin pauses our app — we keep data, stop processing.
  suspended     Boolean          @default(false)
  // Paused while ingestion is over budget caps; resumed by admin.
  paused        Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  repositories  Repository[]
  users         InstallationUser[]
  subscription  Subscription?
  credentials   ProviderCredential[]
  reviewConfigs ReviewConfiguration[]

  @@index([accountLogin])
}

enum AccountType {
  USER
  ORGANIZATION
}

/// Many-to-many: which users belong to which installations.
model InstallationUser {
  installationId String
  userId         String
  role           InstallationRole @default(MEMBER)
  createdAt      DateTime         @default(now())

  installation   Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([installationId, userId])
  @@index([userId])
}

enum InstallationRole {
  OWNER
  MEMBER
}

/// A repository the user has opted-in to ingest.
model Repository {
  id              String           @id @default(cuid())
  installationId  String
  installation    Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  githubId        Int              @unique
  owner           String
  name            String
  defaultBranch   String
  // User must explicitly enable a repo before ingestion starts.
  enabled         Boolean          @default(false)
  ingestionState  IngestionState   @default(NOT_STARTED)
  // High-water mark for incremental syncs — only fetch updates after this timestamp.
  ingestedThrough DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  pullRequests    PullRequest[]
  chunks          Chunk[]
  aiReviews       AiReview[]
  reviewConfigs   ReviewConfiguration[]

  @@unique([owner, name])
  @@index([installationId, enabled])
}

enum IngestionState {
  NOT_STARTED
  DISCOVERING
  HYDRATING
  CHUNKING
  EMBEDDING
  ACTIVE
  FAILED
  PAUSED
}

// -----------------------------------------------------------------------------
// Subscriptions, plans, usage meters
// -----------------------------------------------------------------------------
//
// Subscription tracking is ALWAYS active. Enforcement (rate-limit / paywall) is
// gated by the `billing.enforcement` feature flag — flipping it activates
// enforcement within ~5 minutes (FeatureFlag service TTL).
// -----------------------------------------------------------------------------

/// A subscription tier with optional limits. `null` limits = unlimited.
model Plan {
  id                  String         @id @default(cuid())
  slug                String         @unique
  name                String
  active              Boolean        @default(true)

  // Limits — null means unlimited. Enforced by EntitlementService.
  maxRepositories     Int?
  maxQueriesPerMonth  Int?
  maxIngestionTokens  BigInt?
  maxEmbeddingTokens  BigInt?
  // Code review limits.
  maxPrsPerMonth      Int?
  maxFilesPerPr       Int?

  // Billing metadata.
  priceMonthlyCents   Int?
  stripePriceId       String?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  subscriptions       Subscription[]
}

/// One subscription per Installation.
model Subscription {
  id                    String              @id @default(cuid())
  installationId        String              @unique
  installation          Installation        @relation(fields: [installationId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan                @relation(fields: [planId], references: [id])

  status                SubscriptionStatus
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAt              DateTime?
  canceledAt            DateTime?
  trialEnd              DateTime?

  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}


// -----------------------------------------------------------------------------
// Feature flags
// -----------------------------------------------------------------------------

/// DB-backed feature flag. Read with a 5-minute in-process cache (see @repo/flags).
model FeatureFlag {
  id              String   @id @default(cuid())
  /// Stable key — e.g., 'billing.enforcement', 'retrieval.rerank'.
  key             String   @unique
  /// Default value if no override matches.
  enabled         Boolean  @default(false)
  /// 0–100. When set, deterministic hash of `installationId` decides per-install.
  rolloutPercent  Int?
  /// Optional explicit per-installation overrides: `{ "<installationId>": true | false }`.
  overrides       Json?
  description     String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([key])
}

// -----------------------------------------------------------------------------
// Provider credentials (BYO-LLM)
// -----------------------------------------------------------------------------

/// A user-supplied API credential for an external provider.
/// Secrets stored encrypted via @repo/crypto (AES-256-GCM).
/// One credential per (installation, kind) — replaces, doesn't append.
model ProviderCredential {
  id                    String                    @id @default(cuid())
  installationId        String
  installation          Installation              @relation(fields: [installationId], references: [id], onDelete: Cascade)

  kind                  ProviderCredentialKind
  /// Provider identifier — 'openai', 'anthropic', 'google', etc.
  /// Validated against the factory's known kinds at write time.
  providerKind          String

  /// AES-256-GCM ciphertext of the API key. NEVER plaintext.
  /// Layout: [keyVersion(1B)] [iv(12B)] [authTag(16B)] [ciphertext(N)]
  encryptedSecret       Bytes
  /// For future master-key rotation.
  encryptionKeyVersion  Int                       @default(1)

  // Non-secret config.
  model                 String?
  baseUrl               String?
  organizationId        String?
  metadata              Json?

  // Status — populated by ProviderCredentialService.validate-before-store flow.
  active                Boolean                   @default(true)
  lastValidatedAt       DateTime?
  lastValidationError   String?

  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@unique([installationId, kind])
  @@index([installationId])
}

enum ProviderCredentialKind {
  LLM
  EMBEDDING
  RERANK
}

// -----------------------------------------------------------------------------
// GitHub artifacts (Phase 1: scaffolding only — fully populated in M2/M3)
// -----------------------------------------------------------------------------

model PullRequest {
  id              String              @id @default(cuid())
  repositoryId    String
  repository      Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  number          Int
  githubNodeId    String              @unique

  title           String
  body            String?
  state           PullRequestState
  authorLogin     String?
  authorId        Int?

  createdAt       DateTime
  updatedAt       DateTime
  closedAt        DateTime?
  mergedAt        DateTime?
  mergeCommitSha  String?
  baseRef         String
  headRef         String

  labels          String[]
  changedFiles    Int                 @default(0)
  additions       Int                 @default(0)
  deletions       Int                 @default(0)
  /// Top-N filenames touched, denormalized for retrieval filters.
  filesTouched    String[]

  aiReviews       AiReview[]

  @@unique([repositoryId, number])
  @@index([repositoryId, state, updatedAt])
  @@index([repositoryId, mergedAt])
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
}


// -----------------------------------------------------------------------------
// Retrieval layer (Chunk + ChunkEmbedding)
// -----------------------------------------------------------------------------

/// A unit of meaning extracted from one or more GitHub artifacts.
/// Multiple chunks share a `narrativeKey` to allow grouping at retrieval time.
model Chunk {
  id              String            @id @default(cuid())
  repositoryId    String
  repository      Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  sourceKind      ChunkSourceKind
  /// FK back to the source row (PullRequest.id, Issue.id, ReviewComment threadRoot, etc.)
  sourceId        String

  /// Shared key across all chunks of one narrative — e.g., 'pr:repo123:1847'.
  /// Lets retrieval collapse 12 fragments back into 1 narrative unit.
  narrativeKey    String
  ordinal         Int

  /// The exact preprocessed text that was embedded.
  content         String
  /// SHA-256 hex of `content`. Drives idempotent re-embedding.
  contentHash     String
  tokens          Int

  // Denormalized metadata for retrieval-time filters (no joins).
  authorLogin     String?
  artifactCreatedAt DateTime
  artifactUpdatedAt DateTime
  state           String?
  labels          String[]
  filesTouched    String[]

  // Extra metadata for CODE_FILE chunks: { functionName, startLine, endLine, language }.
  // Stored as JSON to avoid additional columns — never use for filtering, only for display.
  metadata        Json?

  // FTS column populated by trigger after schema setup migration.
  // Declared as Unsupported because Prisma doesn't model tsvector directly.
  searchVector    Unsupported("tsvector")?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  embeddings      ChunkEmbedding[]

  @@index([repositoryId, sourceKind, artifactCreatedAt])
  @@index([narrativeKey])
  @@index([contentHash])
}

enum ChunkSourceKind {
  PR_HEADER
  PR_REVIEW_THREAD
  PR_DISCUSSION
  ISSUE_HEADER
  ISSUE_DISCUSSION
  COMMIT
  CODE_FILE
}

/// Vector embedding for a chunk. Separated from Chunk so:
///   1. Chunk filter scans aren't bloated by 4KB vectors.
///   2. Multiple model versions can coexist during a migration.
model ChunkEmbedding {
  id            String   @id @default(cuid())
  chunkId       String
  chunk         Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  /// 'openai' | 'voyage' | etc. — must match a known EmbeddingProviderKind.
  model         String
  /// Specific model identifier — e.g., 'text-embedding-3-large'.
  modelVersion  String

  /// pgvector type — 1536 dims matches voyage-code-2 and text-embedding-3-large.
  embedding     Unsupported("vector(1536)")

  createdAt     DateTime @default(now())

  @@unique([chunkId, model, modelVersion])
}

// -----------------------------------------------------------------------------
// Ingestion & ops
// -----------------------------------------------------------------------------


/// Webhook delivery audit + idempotency.
/// `deliveryId` (X-GitHub-Delivery header) is unique → re-deliveries dedupe.
model WebhookDelivery {
  id           String    @id @default(cuid())
  deliveryId   String    @unique
  event        String
  action       String?
  payload      Json
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?
  error        String?

  @@index([event, receivedAt])
}


// =============================================================================
// AI Code Review
// =============================================================================

/// Per-installation (or per-repository) settings that control review behaviour.
///
/// Resolution order at review time:
///   1. Repository-specific config (repositoryId IS NOT NULL) if it exists.
///   2. Installation-wide default (repositoryId IS NULL).
///
/// NOTE: database UNIQUE does not cover the NULL case in PostgreSQL. Uniqueness
/// of the (installationId, repositoryId=NULL) pair is enforced at the service layer.
model ReviewConfiguration {
  id                  String           @id @default(cuid())
  installationId      String
  installation        Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  /// NULL = installation-wide default; non-NULL = repository override.
  repositoryId        String?
  repository          Repository?      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  enabled             Boolean          @default(true)
  /// COMMENT = post inline comments only. REQUEST_CHANGES (future) = block merge.
  reviewMode          ReviewMode       @default(COMMENT)
  /// Glob patterns to skip — e.g. ["*.lock", "dist/**", "generated/**"].
  ignorePaths         String[]
  /// GitHub logins to skip — e.g. ["dependabot[bot]", "renovate[bot]"].
  ignoreAuthors       String[]
  /// Minimum severity to post an inline comment. Lower-severity findings are
  /// included in the PR summary but not posted as line-level review comments.
  severityThreshold   AiReviewSeverity @default(WARNING)
  /// Hard cap on files reviewed per PR. Files beyond this limit are noted in summary.
  maxFilesPerPr       Int              @default(20)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([installationId])
  @@index([repositoryId])
}

enum ReviewMode {
  /// Post inline comments only — never requests changes or blocks merge.
  COMMENT
  /// Request changes (blocks merge) when CRITICAL issues are found.
  REQUEST_CHANGES
}

/// One AI review per (repository, PR number, commit SHA).
/// Pinned to commitSha so that pushing new commits creates a fresh review row
/// instead of mutating the old one (GitHub reviews are immutable after submission).
model AiReview {
  id                  String          @id @default(cuid())
  repositoryId        String
  repository          Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  /// NULL when webhook arrives before the PR is upserted into PullRequest table.
  pullRequestId       String?
  pullRequest         PullRequest?    @relation(fields: [pullRequestId], references: [id], onDelete: SetNull)
  /// Denormalized so we can query reviews without joining PullRequest.
  pullRequestNumber   Int
  /// GitHub commit SHA this review is for. Drives idempotency.
  commitSha           String

  status              AiReviewStatus  @default(PENDING)
  /// Top-level PR summary comment text, posted as a single GitHub review body.
  summary             String?
  /// GitHub review ID returned after posting — used to detect already-posted reviews.
  githubReviewId      BigInt?
  /// Total inline comments posted (populated when COMPLETED).
  totalComments       Int             @default(0)

  startedAt           DateTime?
  completedAt         DateTime?
  /// Last error message on FAILED status.
  error               String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  comments            AiReviewComment[]

  /// One review per (repo, PR, commit) — prevents duplicate reviews on webhook re-delivery.
  @@unique([repositoryId, pullRequestNumber, commitSha])
  @@index([repositoryId, status])
  @@index([pullRequestId])
  @@index([repositoryId, createdAt])
}

enum AiReviewStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  /// PR was merged/closed before review completed, or matched an ignore rule.
  SKIPPED
}

/// A single inline review comment generated by the AI for a specific file line.
model AiReviewComment {
  id              String           @id @default(cuid())
  reviewId        String
  review          AiReview         @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  /// Relative file path within the repository — e.g. "src/auth/service.ts".
  filePath        String
  /// Actual file line number on the new (RIGHT) side of the diff.
  line            Int
  /// Which side of the diff the comment applies to.
  side            DiffSide         @default(RIGHT)

  /// Markdown body of the review comment.
  body            String
  severity        AiReviewSeverity
  /// Optional fenced code block with a suggested replacement for the flagged lines.
  suggestion      String?

  /// GitHub comment ID populated after the review is posted. NULL until then.
  githubCommentId BigInt?

  /// Set to true by a user who has reviewed and dismissed this finding.
  dismissed       Boolean          @default(false)
  dismissedById   String?
  dismissedAt     DateTime?

  createdAt       DateTime         @default(now())

  @@index([reviewId, severity])
  @@index([reviewId, filePath])
}

enum AiReviewSeverity {
  /// Nitpick / style / informational. Not posted inline unless threshold is INFO.
  INFO
  /// Suboptimal code — notable but not blocking.
  WARNING
  /// Bug, security issue, or significant logic error — should be addressed.
  ERROR
  /// Critical security vulnerability or data-loss risk — must be fixed.
  CRITICAL
}

enum DiffSide {
  /// Left side of the diff (old file).
  LEFT
  /// Right side of the diff (new file). Default for most AI comments.
  RIGHT
}
