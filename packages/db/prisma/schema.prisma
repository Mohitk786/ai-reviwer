
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../src/generated/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector enables the `vector` column type used by ChunkEmbedding.
  extensions = [pgvector(map: "vector")]
}


/// A GitHub user who has logged into our app.
model User {
  id            String   @id @default(cuid())
  githubId      Int      @unique
  githubLogin   String
  email         String?
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  installations InstallationUser[]

  @@index([githubLogin])
}

/// A GitHub App installation — represents an org or user that has authorized our app.
model Installation {
  id            String           @id @default(cuid())
  githubId      Int              @unique
  accountLogin  String
  accountType   AccountType
  // True when org admin pauses our app — we keep data, stop processing.
  suspended     Boolean          @default(false)
  // Paused while ingestion is over budget caps; resumed by admin.
  paused        Boolean          @default(false)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  repositories  Repository[]
  users         InstallationUser[]
  subscription  Subscription?
  credentials   ProviderCredential[]
  reviewConfigs ReviewConfiguration[]

  @@index([accountLogin])
}

enum AccountType {
  USER
  ORGANIZATION
}

/// Many-to-many: which users belong to which installations.
model InstallationUser {
  installationId String
  userId         String
  role           InstallationRole @default(MEMBER)
  createdAt      DateTime         @default(now())

  installation   Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([installationId, userId])
  @@index([userId])
}

enum InstallationRole {
  OWNER
  MEMBER
}

/// A repository  that user has allowed to be ingested.
model Repository {
  id              String           @id @default(cuid())
  installationId  String
  installation    Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  githubId        Int              @unique    //github repository id
  owner           String
  name            String
  defaultBranch   String
  enabled         Boolean          @default(false)
  ingestionState  IngestionState   @default(NOT_STARTED)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  pullRequests      PullRequest[]
  chunks            Chunk[]
  aiReviews         AiReview[]
  reviewConfigs     ReviewConfiguration[]
  reviewMemories    ReviewMemory[]
  repoKnowledge     RepoKnowledge[]
  reviewConversations ReviewConversation[]

  @@unique([owner, name])
  @@index([installationId, enabled])
}

enum IngestionState {
  NOT_STARTED
  DISCOVERING
  HYDRATING
  CHUNKING
  EMBEDDING
  ACTIVE
  FAILED
  PAUSED
}

// A subscription tier with optional limits. `null` limits = unlimited.
model Plan {
  id                  String         @id @default(cuid())
  slug                String         @unique
  name                String
  active              Boolean        @default(true)

  // Limits — null means unlimited. Enforced by EntitlementService.
  maxRepositories     Int?
  maxQueriesPerMonth  Int?
  maxIngestionTokens  BigInt?
  maxEmbeddingTokens  BigInt?
  // Code review limits.
  maxPrsPerMonth      Int?
  maxFilesPerPr       Int?

  // Billing metadata.
  priceMonthlyCents   Int?
  stripePriceId       String?

  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  subscriptions       Subscription[]
}

/// One subscription per Installation.
model Subscription {
  id                    String              @id @default(cuid())
  installationId        String              @unique
  installation          Installation        @relation(fields: [installationId], references: [id], onDelete: Cascade)
  planId                String
  plan                  Plan                @relation(fields: [planId], references: [id])

  status                SubscriptionStatus
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  cancelAt              DateTime?
  canceledAt            DateTime?
  trialEnd              DateTime?

  stripeCustomerId      String?             @unique
  stripeSubscriptionId  String?             @unique

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
  PAUSED
}

/// DB-backed feature flag. see @repo/flags.
model FeatureFlag {
  id              String   @id @default(cuid())
  key             String   @unique
  enabled         Boolean  @default(false)
  /// 0–100. When set, deterministic hash of `installationId` decides per-install.
  rolloutPercent  Int?
  /// Optional explicit per-installation overrides: `{ "<installationId>": true | false }`.
  overrides       Json?
  description     String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([key])
}

// -----------------------------------------------------------------------------
// Provider credentials (BYO-LLM)
// -----------------------------------------------------------------------------
model ProviderCredential {
  id                    String                    @id @default(cuid())
  installationId        String
  installation          Installation              @relation(fields: [installationId], references: [id], onDelete: Cascade)

  kind                  ProviderCredentialKind
  /// Provider identifier — 'openai', 'anthropic', 'google', etc.
  providerKind          String

  /// AES-256-GCM ciphertext of the API key. NEVER plaintext.
  encryptedSecret       Bytes
  encryptionKeyVersion  Int                       @default(1)  //yeh batata hai ki API key ko kaun si version ki encryption key se encrypt kiya gaya tha.

  // Non-secret config.
  model                 String?
  baseUrl               String?
  organizationId        String?
  metadata              Json?

  active                Boolean                   @default(true)
  lastValidatedAt       DateTime?
  lastValidationError   String?

  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@unique([installationId, kind])
  @@index([installationId])
}

enum ProviderCredentialKind {
  LLM
  EMBEDDING
}

model PullRequest {
  id              String              @id @default(cuid())
  repositoryId    String
  repository      Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  number          Int

  title           String
  body            String?          //PR description
  state           PullRequestState
  authorLogin     String?          //developer who created the PR
  authorId        Int?

  createdAt       DateTime
  updatedAt       DateTime
  closedAt        DateTime?
  mergedAt        DateTime?
  mergeCommitSha  String?
  baseRef         String
  headRef         String

  labels          String[]            //tags on PR like bug, feature, etc.
  changedFiles    Int                 @default(0)
  additions       Int                 @default(0)
  deletions       Int                 @default(0)
  filesTouched    String[]            //path of files changed in the PR

  aiReviews       AiReview[]

  @@unique([repositoryId, number])
  @@index([repositoryId, state, updatedAt])
  @@index([repositoryId, mergedAt])
}

enum PullRequestState {
  OPEN
  CLOSED
  MERGED
}


// -----------------------------------------------------------------------------
// Retrieval layer (Chunk + ChunkEmbedding)
// -----------------------------------------------------------------------------

model Chunk {
  id              String            @id @default(cuid())
  repositoryId    String
  repository      Repository        @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  sourceKind      ChunkSourceKind
  /// FK back to the source row (PullRequest.id,  ReviewComment  etc.)
  sourceId        String       

  /// Shared key across all chunks of one file in a PR — e.g., 'pr:repo123:1847'.
  narrativeKey    String
  ordinal         Int

  /// The exact text that was embedded.
  content         String
  tokens          Int

  // Denormalized metadata for retrieval-time filters 
  authorLogin     String?
  artifactCreatedAt DateTime
  artifactUpdatedAt DateTime
  state           String?
  labels          String[]
  filesTouched    String[]

  // Extra metadata for CODE_FILE chunks: { functionName, startLine, endLine, language }.
  metadata        Json?

  // FTS column populated by trigger after schema setup migration.
  // Declared as Unsupported because Prisma doesn't model tsvector directly.
  searchVector    Unsupported("tsvector")?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  embeddings      ChunkEmbedding[]

  @@index([repositoryId, sourceKind, artifactCreatedAt])
  @@index([narrativeKey])
}

enum ChunkSourceKind {
  PR_HEADER
  PR_REVIEW_THREAD
  PR_DISCUSSION
  COMMIT
  CODE_FILE
}

/// Vector embedding for a chunk. Separated from Chunk so:
///   1. Chunk filter scans aren't bloated by 4KB vectors.
///   2. Multiple model versions can coexist during a migration.
model ChunkEmbedding {
  id            String   @id @default(cuid())
  chunkId       String
  chunk         Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  // model used to embed the chunk
  model         String
  // version of the model used to embed the chunk - text-embedding-3-large_v1
  modelVersion  String
  embedding     Unsupported("vector(1536)")

  createdAt     DateTime @default(now())
  @@unique([chunkId, model, modelVersion])
}



model WebhookDelivery {
  id           String    @id @default(cuid())
  deliveryId   String    @unique //send by github to our webhook endpoint
  event        String
  action       String?
  payload      Json
  receivedAt   DateTime  @default(now())
  processedAt  DateTime?
  error        String?

  @@index([event, receivedAt])
}


// =============================================================================
// AI Code Review
// =============================================================================

model ReviewConfiguration {
  id                  String           @id @default(cuid())
  installationId      String
  installation        Installation     @relation(fields: [installationId], references: [id], onDelete: Cascade)
  repositoryId        String?
  repository          Repository?      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  enabled             Boolean          @default(true)
  /// COMMENT = post inline comments only. REQUEST_CHANGES (future) = block merge.
  reviewMode          ReviewMode       @default(COMMENT)
  /// Glob patterns to skip — e.g. ["*.lock", "dist/**", "generated/**"].
  ignorePaths         String[]
  ignoreAuthors       String[]
  severityThreshold   AiReviewSeverity @default(WARNING)
  maxFilesPerPr       Int              @default(20)

  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([installationId])
  @@index([repositoryId])
}

enum ReviewMode {
  /// Post inline comments only — never requests changes or blocks merge.
  COMMENT
  /// Request changes (blocks merge) when CRITICAL issues are found.
  REQUEST_CHANGES
}

/// One AI review per (repository, PR number, commit SHA).
model AiReview {
  id                  String          @id @default(cuid())
  repositoryId        String
  repository          Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  /// NULL when webhook arrives before the PR is upserted into PullRequest table.
  pullRequestId       String?
  pullRequest         PullRequest?    @relation(fields: [pullRequestId], references: [id], onDelete: SetNull)
  pullRequestNumber   Int
  commitSha           String

  status              AiReviewStatus  @default(PENDING)
  summary             String?
  /// GitHub review ID returned after posting — used to detect already-posted reviews.
  githubReviewId      BigInt?
  totalComments       Int             @default(0)

  startedAt           DateTime?
  completedAt         DateTime?
  /// Last error message on FAILED status.
  error               String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  comments            AiReviewComment[]

  @@unique([repositoryId, pullRequestNumber, commitSha])
  @@index([repositoryId, status])
  @@index([pullRequestId])
  @@index([repositoryId, createdAt])
}

enum AiReviewStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

/// A single inline review comment generated by the AI for a specific file line.
model AiReviewComment {
  id              String           @id @default(cuid())
  reviewId        String
  review          AiReview         @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  filePath        String
  /// Actual file line number on the new (RIGHT) side of the diff.
  line            Int
  side            DiffSide         @default(RIGHT)

  /// Markdown body of the review comment.
  body            String
  severity        AiReviewSeverity
  /// Optional fenced code block with a suggested replacement for the flagged lines.
  suggestion      String?

  githubCommentId BigInt?

  /// Set to true by a user who has reviewed and dismissed this finding.
  dismissed       Boolean          @default(false)
  dismissedById   String?
  dismissedAt     DateTime?

  createdAt       DateTime         @default(now())

  reviewMemory    ReviewMemory?
  conversations   ReviewConversation[]

  @@index([reviewId, severity])
  @@index([reviewId, filePath])
  @@index([githubCommentId])
}

enum AiReviewSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum DiffSide {
  LEFT
  RIGHT
}

// =============================================================================
// Layer 2 — Review Memory
// =============================================================================

/// One row per AiReviewComment — stores the diff chunk + AI comment as a
/// searchable memory unit so future reviews can cite past decisions.
model ReviewMemory {
  id                String              @id @default(cuid())
  repositoryId      String
  repository        Repository          @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  aiReviewCommentId String              @unique
  aiReviewComment   AiReviewComment     @relation(fields: [aiReviewCommentId], references: [id], onDelete: Cascade)

  pullRequestNumber Int
  filePath          String
  /// The diff patch snippet that triggered this comment .
  diffChunk         String
  /// The AI's comment body 
  commentBody       String
  severity          AiReviewSeverity
  category          ReviewCategory      @default(CORRECTNESS)

  /// Whether the developer accepted or dismissed this finding.
  outcome           ReviewMemoryOutcome @default(PENDING)
  outcomeAt         DateTime?

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  embedding         ReviewMemoryEmbedding?

  @@index([repositoryId, outcome])
  @@index([repositoryId, category])
  @@index([repositoryId, createdAt])
}

model ReviewMemoryEmbedding {
  id             String       @id @default(cuid())
  reviewMemoryId String       @unique
  reviewMemory   ReviewMemory @relation(fields: [reviewMemoryId], references: [id], onDelete: Cascade)
  model          String
  modelVersion   String
  embedding      Unsupported("vector(1536)")

  @@map("ReviewMemoryEmbedding")
}

enum ReviewMemoryOutcome {
  /// No developer reaction recorded yet.
  PENDING
  /// Developer acknowledged the issue and made a fix.
  ACCEPTED
  /// Developer explicitly marked this as not applicable.
  DISMISSED
}

enum ReviewCategory {
  SECURITY
  PERFORMANCE
  STYLE
  CORRECTNESS
  ARCHITECTURE
  TEST_COVERAGE
}

// =============================================================================
// Layer 2 — Repo Knowledge (extracted from developer comments)
// =============================================================================

model RepoKnowledge {
  id               String                 @id @default(cuid())
  repositoryId     String
  repository       Repository             @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  /// The extracted knowledge statement in plain English.
  content          String
  kind             KnowledgeKind

  /// GitHub PR number where this knowledge was found.
  sourcePrNumber   Int?
  /// Full GitHub URL to the source comment.
  sourceCommentUrl String?

  createdAt        DateTime               @default(now())

  embedding        RepoKnowledgeEmbedding?

  @@index([repositoryId])
  @@index([repositoryId, kind])
}

/// pgvector embedding for a RepoKnowledge row.
model RepoKnowledgeEmbedding {
  id              String        @id @default(cuid())
  repoKnowledgeId String        @unique
  repoKnowledge   RepoKnowledge @relation(fields: [repoKnowledgeId], references: [id], onDelete: Cascade)
  model           String
  modelVersion    String
  embedding       Unsupported("vector(1536)")

  @@map("RepoKnowledgeEmbedding")
}

enum KnowledgeKind {
  /// High-level architectural decisions ("we use CQRS", "event-sourced domain").
  ARCHITECTURE
  /// Coding conventions ("all handlers validate with Zod", "use repository pattern").
  CONVENTION
  /// Feature-specific behaviour ("bookings use soft deletes, not hard").
  FEATURE
  /// Hard constraints ("never expose raw DB IDs in URLs").
  CONSTRAINT
  /// Domain terminology ("we call users 'members', not 'accounts'").
  TERMINOLOGY
}


/// Tracks when a developer asks a question on an AI review comment
/// and the AI reply that was generated and posted.
model ReviewConversation {
  id                 String          @id @default(cuid())
  repositoryId       String
  repository         Repository      @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  aiReviewCommentId  String
  aiReviewComment    AiReviewComment @relation(fields: [aiReviewCommentId], references: [id], onDelete: Cascade)

  developerLogin     String
  /// GitHub ID of the developer's question comment.
  developerCommentId BigInt
  developerQuestion  String
  /// The AI reply body that was posted to GitHub.
  aiReply            String?
  repliedAt          DateTime?

  createdAt          DateTime        @default(now())

  @@index([repositoryId])
  @@index([aiReviewCommentId])
}
